# Required: Discord bot token used to log in.
DISCORD_TOKEN=

# Optional: command prefix used by the bot.
DISCORD_PREFIX=!

# Optional: log verbosity.
LOG_LEVEL=info

# Optional: HTTP API bind address and port.
HTTP_HOST=127.0.0.1
HTTP_PORT=3000

# Required: protects /api/music/* via the x-api-token header.
API_TOKEN=change-me

# Optional: mention forwarding webhook. Used only for forwarding mention events to n8n.
N8N_WEBHOOK_URL=

# Optional: timeout for the n8n webhook request, in milliseconds.
N8N_TIMEOUT_MS=10000

# Optional: default music volume.
DEFAULT_VOLUME=0.5
